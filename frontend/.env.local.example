# Copy this file to .env.local and fill in real values. Never commit .env.local itself.
#
# These are server-side only (used inside app/api/*/route.js) -- they are
# NEVER exposed to the browser, which is the whole point of the proxy
# pattern this frontend uses. Do NOT prefix these with NEXT_PUBLIC_, which
# would expose them to client-side code instead.

# Where your FastAPI backend is running.
BACKEND_URL=http://localhost:8000

# The same CURATOR_API_KEY value from the backend's own .env file.
CURATOR_API_KEY=your_backend_curator_api_key_here
