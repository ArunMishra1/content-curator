# Copy this file to .env and fill in your real values. Never commit .env itself.
ANTHROPIC_API_KEY=your_key_here

# Key required by callers of this API (sent as the X-API-Key header).
# Generate a strong random one, e.g.: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
CURATOR_API_KEY=your_own_generated_key_here
